# Copy this to .env or .env.local and fill in real values.
# The scripts auto-load .env first, then .env.local. Already-exported shell env wins.

# Prefer an AWS CLI/SSO profile when possible.
AWS_PROFILE=
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1

# Alternative to AWS_PROFILE: temporary or IAM-user credentials.
# Leave these empty if AWS_PROFILE/SSO is configured.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# AWS Bedrock Batch Inference.
BEDROCK_ROLE_ARN=arn:aws:iam::<account-id>:role/<bedrock-batch-role>
BEDROCK_MODEL_ID=anthropic.claude-opus-4-6-v1
BEDROCK_BATCH_INPUT_S3=s3://<bucket>/teacher-batches/input
BEDROCK_BATCH_OUTPUT_S3=s3://<bucket>/teacher-batches/output
BEDROCK_TIMEOUT_HOURS=24
BEDROCK_MAX_TOKENS=32000
BEDROCK_TEMPERATURE=0.0

# Local teacher batch paths.
TEACHER_BATCH_DIR=data/teacher_batches/pilot-001
TEACHER_QUERIES_FILE=data/query_sets/reranker_pilot_500.txt
TEACHER_SNAPSHOTS_DIR=data/snapshots
TEACHER_LABELS_DIR=data/labels
TEACHER_MAX_SENTENCES=16

# topa.page retrieval used by teacher_batch.py prepare-ranking --queries.
TOPA_BASE_URL=https://www.topa.page
TOPA_SEARCH_PATH=/api/search/search-candidates
# Leave blank to omit top_k and fetch the full candidate set.
TOPA_TOP_K=

# Only needed for the existing sync Anthropic API path.
ANTHROPIC_API_KEY=
